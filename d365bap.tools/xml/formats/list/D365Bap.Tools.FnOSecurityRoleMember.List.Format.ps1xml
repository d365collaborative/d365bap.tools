<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <ViewDefinitions>
    <View>
            <Name>D365Bap.Tools.FnOSecurityRoleMember</Name>
            <ViewSelectedBy>
                <TypeName>D365Bap.Tools.FnOSecurityRoleMember</TypeName>
            </ViewSelectedBy>
            <ListControl>
                <ListEntries>
                    <ListEntry>
                        <ListItems>
                            <ListItem>
                                <PropertyName>FscmUserId</PropertyName>
                            </ListItem>
                            <ListItem>
                                <PropertyName>FscmRoleId</PropertyName>
                            </ListItem>
                            <ListItem>
                                <PropertyName>Status</PropertyName>
                            </ListItem>
                            <ListItem>
                                <PropertyName>Assignment</PropertyName>
                            </ListItem>
                            <ListItem>
                                <PropertyName>License</PropertyName>
                            </ListItem>
                        </ListItems>
                    </ListEntry>
                </ListEntries>
            </ListControl>
        </View>
  </ViewDefinitions>
</Configuration>